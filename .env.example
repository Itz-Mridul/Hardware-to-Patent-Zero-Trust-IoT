# ═══════════════════════════════════════════════════════════════
# Zero-Trust IoT Security Gateway — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to git!
# ═══════════════════════════════════════════════════════════════

# ── WiFi (reference only — ESP32 credentials are in firmware) ──
WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# ── MQTT Broker ────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883

# ── Raspberry Pi Network ──────────────────────────────────────
PI_LOCAL_IP=192.168.X.X

# ── Blockchain (Ganache) ──────────────────────────────────────
BLOCKCHAIN_URL=http://127.0.0.1:7545
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_ADDRESS_HERE
ENABLE_BLOCKCHAIN=false

# ── ML Models ─────────────────────────────────────────────────
MODEL_PATH=ml_models/device_authenticator.h5
SCALER_PATH=ml_models/scaler.pkl

# ── Database ──────────────────────────────────────────────────
IOT_DB_PATH=pi_backend/security.db

# ── Telegram Alerts ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ── GPIO Pins (Raspberry Pi BCM numbering) ────────────────────
SW420_GPIO_PIN=17
DHT22_GPIO_PIN=4
POWER_RELAY_PIN=23
HEARTBEAT_GPIO_IN=17
RELAY_KILL_GPIO_OUT=18

# ── Security Thresholds ──────────────────────────────────────
CONFIDENCE_THRESHOLD=75.0
TEMP_THRESHOLD=45.0
TEMP_RATE_PER_MIN=5.0
THERMAL_KILL_THRESHOLD=70.0
CPU_KILL_THRESHOLD=80.0
TAMPER_DELTA_THRESHOLD=20.0

# ── Nonce Challenger ──────────────────────────────────────────
NONCE_INTERVAL_S=30
NONCE_TIMEOUT_S=8.0
FPGA_THRESHOLD_US=10
NONCE_TARGET_DEVICE=ESP32_CAM_PERIMETER

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_PORT=5001
BLOCKCHAIN_BRIDGE_PORT=5010

# ── Honey-PIN (admin) ────────────────────────────────────────
REAL_PIN=1234

# ── Network Interface ────────────────────────────────────────
GATEWAY_IFACE=wlan0
