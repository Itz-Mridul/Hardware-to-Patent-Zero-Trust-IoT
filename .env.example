# ═══════════════════════════════════════════════════════════════
# Zero-Trust IoT Security Gateway — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── WiFi (reference only — ESP32 credentials are in firmware) ──
WIFI_SSID="Room203"
WIFI_PASSWORD="Hostel@203"

# ── Security Keys ────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Store on ESP32 via flashSecretKey(), load on Pi from this file.
HMAC_SECRET_KEY=b3962f909a1507407466c4c962711d6d6f8ed9c98064e56592f31a13d6b035b9

# ── MQTT Broker ────────────────────────────────────────────────
# Set to localhost because the Python services and Mosquitto 
# broker are both running together on the Pi.
MQTT_BROKER=localhost
MQTT_PORT=1883

# ── Raspberry Pi Network ──────────────────────────────────────
# Based on your previous C++ firmware, this was your IP. 
# Double check by typing 'hostname -I' on your Pi.
PI_LOCAL_IP=192.168.1.113

# ── Blockchain (Ganache) ──────────────────────────────────────
BLOCKCHAIN_URL=http://127.0.0.1:7545
CONTRACT_ADDRESS="0x5fc5e9432ba7c493a7a9d66447ebd74d7171356e"
ENABLE_BLOCKCHAIN=true

# ── ML Models ─────────────────────────────────────────────────
MODEL_PATH=ml_models/device_authenticator.h5
SCALER_PATH=ml_models/scaler.pkl

# ── Database ──────────────────────────────────────────────────
IOT_DB_PATH=pi_backend/security.db

# ── Telegram Alerts ───────────────────────────────────────────
# You must get these from Telegram. See instructions below.
TELEGRAM_BOT_TOKEN="8687587961:AAGvAknPi_xA75QtPaTkxOGXjT9kMoH877s"
TELEGRAM_CHAT_ID="7782891567"

# ── GPIO Pins (Raspberry Pi BCM numbering) ────────────────────
# These match the exact wiring blueprint we designed.
SW420_GPIO_PIN=17
DHT22_GPIO_PIN=4
POWER_RELAY_PIN=23
HEARTBEAT_GPIO_IN=27
RELAY_KILL_GPIO_OUT=18

# ── Security Thresholds ──────────────────────────────────────
CONFIDENCE_THRESHOLD=75.0
TEMP_THRESHOLD=45.0
TEMP_RATE_PER_MIN=5.0
THERMAL_KILL_THRESHOLD=70.0
CPU_KILL_THRESHOLD=80.0
TAMPER_DELTA_THRESHOLD=20.0

# ── Nonce Challenger (Anti-FPGA / Anti-Spoofing) ──────────────
NONCE_INTERVAL_S=30
NONCE_TIMEOUT_S=8.0
FPGA_THRESHOLD_US=10
NONCE_TARGET_DEVICE=ESP32_CAM_PERIMETER

# ── Dashboard & API Ports ─────────────────────────────────────
DASHBOARD_PORT=5001
BLOCKCHAIN_BRIDGE_PORT=5010

# ── Access Codes ──────────────────────────────────────────────
REAL_PIN=1234
DURESS_PIN=9999    # Added this for your Act III Honey-PIN demo!

# ── Network Interface ────────────────────────────────────────
GATEWAY_IFACE=wlan0

# ── Arduino Uno Watchdog (Air-Gapped Kill-Switch) ────────────
# The Arduino connects via USB cable to the Pi.
# Find the port with: ls /dev/ttyUSB* or ls /dev/ttyACM*
# Common values: /dev/ttyUSB0 (FTDI) or /dev/ttyACM0 (CH340)
ARDUINO_SERIAL_PORT=/dev/ttyUSB0
ARDUINO_BAUD_RATE=9600
ARDUINO_PING_INTERVAL_S=10.0